{
  "name": "super-configs",
  "version": "1.4.0",
  "description": "Shared ESLint, Biome, and legacy Prettier configurations for JavaScript, TypeScript, and React projects",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    },
    "./eslint/js": {
      "types": "./lib/eslint/js/index.d.ts",
      "import": "./lib/eslint/js/index.js"
    },
    "./eslint/ts": {
      "types": "./lib/eslint/ts/index.d.ts",
      "import": "./lib/eslint/ts/index.js"
    },
    "./eslint/jest": {
      "types": "./lib/eslint/jest/index.d.ts",
      "import": "./lib/eslint/jest/index.js"
    },
    "./eslint/react/jsx": {
      "types": "./lib/eslint/react/jsx/index.d.ts",
      "import": "./lib/eslint/react/jsx/index.js"
    },
    "./eslint/react/tsx": {
      "types": "./lib/eslint/react/tsx/index.d.ts",
      "import": "./lib/eslint/react/tsx/index.js"
    },
    "./biome": "./biome.json",
    "./prettier": {
      "types": "./lib/prettier/index.d.ts",
      "import": "./lib/prettier/index.js"
    }
  },
  "files": [
    "lib",
    "biome.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('lib', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "check": "npm run lint && npm run biome:check && npm run build",
    "test": "npm run check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "biome:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "release": "semantic-release",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ElJijuna/super-configs.git"
  },
  "keywords": [
    "config",
    "eslint",
    "biome",
    "prettier",
    "typescript",
    "react",
    "eslint-config",
    "prettier-config",
    "biome-config"
  ],
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ElJijuna/super-configs/issues"
  },
  "homepage": "https://github.com/ElJijuna/super-configs#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.0.0",
    "eslint": ">=9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@biomejs/biome": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.1",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.45.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.37.0",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.0.0"
  }
}
